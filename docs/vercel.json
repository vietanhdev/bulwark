{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": ".vitepress/dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/guide/ai-security",
      "destination": "/guide/agent-security",
      "permanent": true
    },
    {
      "source": "/research/lynis-benchmark",
      "destination": "/articles/choosing-a-linux-security-scanner",
      "permanent": true
    },
    {
      "source": "/research/:path*",
      "destination": "/articles/choosing-a-linux-security-scanner",
      "permanent": true
    }
  ]
}
