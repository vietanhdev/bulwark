{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bulwark",
  "mainBinaryName": "bulwark-app",
  "version": "0.2.1",
  "identifier": "com.vietanhnv.bulwark",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Bulwark",
        "width": 1280,
        "height": 800,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../../rules": "rules",
      "../../../decoders": "decoders",
      "../../../log-rules": "log-rules"
    },
    "externalBin": ["binaries/bulwarkctl"]
  }
}
