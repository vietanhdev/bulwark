# ─────────────────────────────────────────────────────────────────────────────
# Rust / Cargo
# ─────────────────────────────────────────────────────────────────────────────
/target
**/target
**/*.rs.bk
*.pdb
# Cargo.lock IS committed on purpose — this workspace ships binaries (bulwarkctl,
# the desktop app), so a locked, reproducible dependency set is what gets released.

# ─────────────────────────────────────────────────────────────────────────────
# Node / frontend (apps/bulwark-app, docs)
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
dist/
.vite/
*.tsbuildinfo
.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─────────────────────────────────────────────────────────────────────────────
# Tauri (desktop app)
# ─────────────────────────────────────────────────────────────────────────────
**/src-tauri/target/
**/src-tauri/gen/
# Bundled CLI sidecars are staged at build time by src-tauri/build.rs, never
# committed (also covered by src-tauri/binaries/.gitignore).
**/src-tauri/binaries/bulwark-cli-*
**/src-tauri/binaries/bulwarkctl-*

# ─────────────────────────────────────────────────────────────────────────────
# VitePress docs site
# ─────────────────────────────────────────────────────────────────────────────
docs/.vitepress/dist/
docs/.vitepress/cache/
.vercel/

# ─────────────────────────────────────────────────────────────────────────────
# Packaging / release artifacts (produced by cargo-deb, generate-rpm, tauri build)
# ─────────────────────────────────────────────────────────────────────────────
*.deb
*.rpm
*.AppImage
bulwarkctl-*-x86_64-linux/
bulwarkctl-*-x86_64-linux.tar.gz

# ─────────────────────────────────────────────────────────────────────────────
# Bulwark runtime data (local scan DB + SQLite sidecars)
# ─────────────────────────────────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ─────────────────────────────────────────────────────────────────────────────
# Secrets / environment
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ─────────────────────────────────────────────────────────────────────────────
# Python (research/)
# ─────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
venv/
.ipynb_checkpoints/

# ─────────────────────────────────────────────────────────────────────────────
# Editors / IDEs
# ─────────────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ─────────────────────────────────────────────────────────────────────────────
# OS cruft
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
Thumbs.db
desktop.ini

# ─────────────────────────────────────────────────────────────────────────────
# Tooling
# ─────────────────────────────────────────────────────────────────────────────
.playwright-mcp/
*.log

# ─────────────────────────────────────────────────────────────────────────────
# Personal / local working files (drafts, notes — never committed)
# ─────────────────────────────────────────────────────────────────────────────
/.local/

# Generated by scripts/flatpak-gen-sources.sh (offline deps for the flatpak build)
packaging/flatpak/cargo-sources.json
packaging/flatpak/node-sources.json
snaplogin

# Flathub submission tree, staged by scripts/flatpak-gen-flathub-manifest.sh.
# Generated from the dev manifest + a tag; regenerate rather than commit it.
/build/

# Playwright
apps/bulwark-app/test-results/
apps/bulwark-app/playwright-report/
apps/bulwark-app/blob-report/
apps/bulwark-app/.playwright/

# Flathub submission working notes. Deliberately untracked: these are preparation material
# for a submission a human writes and posts — a fact sheet to check the manifest against,
# the upstream PR template, and the permissions rationale. They are not build inputs and
# nothing in the packaging reads them, so keeping them in the repo only invites someone to
# paste them verbatim into a PR whose description has to be the submitter's own words.
# They stay on disk locally; regenerate the template with
#   gh api repos/flathub/flathub/contents/.github/pull_request_template.md -q .content | base64 -d
packaging/flatpak/*.md
